#!/usr/bin/env bash
# =============================================================================
# monitor_trafico.sh — Vigilancia automática con activación de defensa
# Curso : Sistemas Operativos de Código Abierto — Guía de Laboratorio 15
# Diseño : Se ejecuta vía cron cada minuto. Si el tráfico TX supera el
#           umbral definido, activa defensa.sh automáticamente.
#
# Instalación del cron (ejecutar una sola vez como root):
#   sudo crontab -e
#   Agregar la línea:
#   * * * * * /ruta/absoluta/monitor_trafico.sh >> /var/log/monitor_lab15.log 2>&1
# =============================================================================
set -euo pipefail

# ── Configuración ─────────────────────────────────────────────────────────────
UMBRAL_MBPS=50          # Umbral en Megabits por segundo que activa la defensa
INTERFAZ="ens33"        # Interfaz de red del servidor (ajustar si es diferente)
RUTA_DEFENSA="/root/lab15/defensa.sh"   # Ruta absoluta al script de defensa
LOG_FILE="/var/log/monitor_lab15.log"
LOCK_FILE="/tmp/defensa_activa.lock"
MUESTRA_SEG=2           # Segundos de muestreo para calcular tasa de tráfico

# ── Timestamp ────────────────────────────────────────────────────────────────
TS() { date '+%Y-%m-%d %H:%M:%S'; }

# =============================================================================
# Función: obtener tasa de TX en Mbps usando /proc/net/dev
# Mide la diferencia de bytes en MUESTRA_SEG segundos → convierte a Mbps
# =============================================================================
obtener_tx_mbps() {
    local iface="$1"

    # Primera lectura de bytes TX (columna 9 en /proc/net/dev)
    local bytes1
    bytes1=$(awk -v iface="${iface}:" '$1==iface {print $10}' /proc/net/dev)

    sleep "$MUESTRA_SEG"

    local bytes2
    bytes2=$(awk -v iface="${iface}:" '$1==iface {print $10}' /proc/net/dev)

    # Calcular diferencia y convertir a Mbps
    # bytes_diff / tiempo / 1000000 * 8 = Mbps
    local mbps
    mbps=$(awk "BEGIN {printf \"%.2f\", ($bytes2 - $bytes1) / $MUESTRA_SEG / 1000000 * 8}")
    echo "$mbps"
}

# =============================================================================
# Función: verificar si la defensa ya está activa
# =============================================================================
defensa_ya_activa() {
    # Verifica si la cadena SYN_RATE_LIMIT existe en iptables
    iptables -L SYN_RATE_LIMIT -n &>/dev/null 2>&1
}

# =============================================================================
# LÓGICA PRINCIPAL
# =============================================================================
echo "[$(TS)] Monitor iniciado. Interfaz: $INTERFAZ | Umbral: ${UMBRAL_MBPS} Mbps"

TX_ACTUAL=$(obtener_tx_mbps "$INTERFAZ")
echo "[$(TS)] Tráfico TX actual: ${TX_ACTUAL} Mbps"

# Comparar usando awk (bash no maneja decimales nativamente)
SUPERA_UMBRAL=$(awk "BEGIN {print ($TX_ACTUAL >= $UMBRAL_MBPS) ? 1 : 0}")

if [[ "$SUPERA_UMBRAL" -eq 1 ]]; then
    echo "[$(TS)] ALERTA: Tráfico ${TX_ACTUAL} Mbps supera umbral de ${UMBRAL_MBPS} Mbps."

    if defensa_ya_activa; then
        echo "[$(TS)] INFO: defensa.sh ya está activa. Sin acción adicional."
    else
        echo "[$(TS)] ACCIÓN: Activando defensa.sh automáticamente..."
        if [[ -x "$RUTA_DEFENSA" ]]; then
            bash "$RUTA_DEFENSA" >> "$LOG_FILE" 2>&1
            echo "[$(TS)] OK: defensa.sh ejecutada exitosamente."
        else
            echo "[$(TS)] ERROR: No se encontró $RUTA_DEFENSA o no es ejecutable."
        fi
    fi
else
    echo "[$(TS)] OK: Tráfico normal (${TX_ACTUAL} Mbps). Sin amenazas detectadas."

    # Si la defensa estaba activa y el tráfico volvió a la normalidad, notificar
    if defensa_ya_activa; then
        echo "[$(TS)] INFO: Tráfico normalizado. Puedes ejecutar reset_lab.sh para limpiar reglas."
    fi
fi

echo "[$(TS)] Monitor finalizado."
echo "---"
